<?xml version="1.0" encoding="UTF-8" ?>
<window id="1101" type="window">
	<!-- ================================================================= -->
	<!-- TMDb Helper skin settings (fires on every boot once initialized)  -->
	<!-- ================================================================= -->
	<onload condition="Skin.HasSetting(Madnox.Settings.Initialized)">Skin.SetBool(TMDbHelper.Service)</onload>
	<onload condition="Skin.HasSetting(Madnox.Settings.Initialized)">Skin.SetString(TMDbHelper.MonitorContainer,7005)</onload>
	<onload condition="Skin.HasSetting(Madnox.Settings.Initialized)">Skin.SetBool(TMDbHelper.DirectCallAuto)</onload>
	<onload condition="Skin.HasSetting(Madnox.Settings.Initialized) + !IsEmpty(Skin.String(TMDbHelper.MonitorContainer))">Skin.Reset(TMDBHelper.MonitorContainer)</onload>
	<onload condition="Skin.HasSetting(Madnox.Settings.Initialized) + [!System.AddonIsEnabled(plugin.video.themoviedb.helper) | !Skin.HasSetting(BlurEnabled)]">Skin.Reset(TMDbHelper.EnableBlur)</onload>
	<onload condition="Skin.HasSetting(Madnox.Settings.Initialized) + System.AddonIsEnabled(plugin.video.themoviedb.helper) + Skin.HasSetting(BlurEnabled)">Skin.SetBool(TMDbHelper.EnableBlur)</onload>

	<!-- ================================================================= -->
	<!-- Intro Video Logic                                                  -->
	<!-- ================================================================= -->
	<onload condition="Skin.HasSetting(Madnox.Settings.Initialized) + !String.IsEmpty(Skin.String(IntroVideoSelectStartupValue))">Skin.SetBool(Madnox.IntroActive)</onload>
	<onload condition="Skin.HasSetting(Madnox.Settings.Initialized) + !String.IsEmpty(Skin.String(IntroVideoSelectStartupValue))">SetFocus(10)</onload>
	<onload condition="Skin.HasSetting(Madnox.Settings.Initialized) + String.IsEmpty(Skin.String(IntroVideoSelectStartupValue))">ReplaceWindow(1103)</onload>

	<onunload>ClearProperty(TMDbHelper.Blur.SourceImage,Home)</onunload>
	<onunload>ClearProperty(TMDbHelper.Blur.Fallback,Home)</onunload>

	<animation effect="fade" delay="1000" time="480">WindowOpen</animation>
	<animation effect="fade" time="480">WindowClose</animation>
	<include>onunload_SkinSettings</include>

	<controls>
		<!-- Escape hatch: if routing stalls for any reason, force out after 1.5s -->
		<control type="image">
			<include>HiddenObject</include>
			<animation effect="fade" start="100" end="100" time="1" delay="1500" onend="ReplaceWindow(1103)" condition="Window.IsVisible(1101)">WindowOpen</animation>
		</control>

		<control type="button" id="10">
			<include>HiddenObject</include>
			<onfocus>ReplaceWindow(1108)</onfocus>
			<onfocus>PlayMedia($ESCINFO[Skin.String(IntroVideoSelectStartupValue)])</onfocus>
		</control>
	</controls>
</window>
